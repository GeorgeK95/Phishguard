pg:StealPersonalData rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#SuspiciousLink
pg:SuspiciousLink rdf:type owl:NamedIndividual ,
                           pg:MessageFeature ;
                  pg:description "The message contains a URL that may lead to a fake or unsafe website." ;
                  pg:keyword ".click" ,
                             ".top" ,
                             ".xyz" ,
                             "bit.ly" ,
                             "http://" ,
                             "login-" ,
                             "secure-" ,
                             "tinyurl" ,
                             "verify-" ;
                  pg:riskScore 30 ;
                  rdfs:label "Suspicious link" .


###  http://example.org/phishguard#TakeOverAccount
pg:TakeOverAccount rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#TakeRequestThreadType
pg:TakeRequestThreadType rdf:type owl:NamedIndividual ,
                                  pg:ThreatType ;
                         pg:hasFeature pg:TakingRequest ;
                         pg:description "The message is from unrecognised person and has intent for the client to go and take the person. " ;
                         rdfs:label "TakeRequestThreadType" .


###  http://example.org/phishguard#TakingRequest
pg:TakingRequest rdf:type owl:NamedIndividual ,
                          pg:MessageFeature ;
                 pg:description "The message is from unrecognised person and has intent for the client to go and take the person. " ;
                 pg:keyword "Pick me up" ;
                 pg:riskScore 66 ;
                 rdfs:label "Taking request" .


###  http://example.org/phishguard#TechSupportBait
pg:TechSupportBait rdf:type owl:NamedIndividual ,
                            pg:MessageFeature ;
                   pg:description "The message claims a device or account has a technical/security problem." ;
                   pg:keyword "call support" ,
                              "device infected" ,
                              "security alert" ,
                              "technical support" ,
                              "virus detected" ;
                   pg:riskScore 20 ;
                   rdfs:label "Tech support bait" .


###  http://example.org/phishguard#TechSupportScam
pg:TechSupportScam rdf:type owl:NamedIndividual ,
                            pg:ThreatType ;
                   pg:hasAttackGoal pg:InstallMalware ,
                                    pg:ReceiveFraudulentPayment ;
                   pg:hasFeature pg:PaymentRequest ,
                                 pg:SuspiciousLink ,
                                 pg:TechSupportBait ,
                                 pg:Urgency ;
                   pg:targetsOrganization pg:PaymentProvider ,
                                          pg:TelecomProvider ;
                   pg:description "A scam that pretends the user has a technical or security issue and must contact fake support." .


###  http://example.org/phishguard#TelecomProvider
pg:TelecomProvider rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#Telegram
pg:Telegram rdf:type owl:NamedIndividual ,
                     pg:CommunicationChannel ;
            rdfs:label "Telegram" .


###  http://example.org/phishguard#TwoFactorCodeRequest
pg:TwoFactorCodeRequest rdf:type owl:NamedIndividual ,
                                 pg:MessageFeature ;
                        pg:description "The message asks the user to provide a two-factor authentication code." ;
                        pg:keyword "2fa" ,
                                   "one-time code" ,
                                   "otp" ,
                                   "security code" ,
                                   "six digit code" ,
                                   "verification code" ;
                        pg:riskScore 35 .


###  http://example.org/phishguard#UnknownSender
pg:UnknownSender rdf:type owl:NamedIndividual ,
                          pg:MessageFeature ;
                 pg:description "The sender is unclear, unofficial or does not match a trusted organization." ;
                 pg:keyword "customer-support" ,
                            "helpdesk" ,
                            "no-reply" ,
                            "support-center" ,
                            "unknown" ;
                 pg:riskScore 10 ;
                 rdfs:label "Unknown sender" .


###  http://example.org/phishguard#Urgency
pg:Urgency rdf:type owl:NamedIndividual ,
                    pg:MessageFeature ;
           pg:description "The message pushes the user to act quickly without proper verification." ;
           pg:keyword "act now" ,
                      "expires today" ,
                      "final notice" ,
                      "immediately" ,
                      "limited time" ,
                      "urgent" ,
                      "within 24 hours" ;
           pg:riskScore 15 ;
           rdfs:label "Urgency language" .


###  http://example.org/phishguard#VerifyOfficialWebsite
pg:VerifyOfficialWebsite rdf:type owl:NamedIndividual ,
                                  pg:Recommendation ;
                         pg:description "Open the official website manually in your browser instead of using the received link." ;
                         rdfs:label "Verify through the official website" .


###  http://example.org/phishguard#Viber
pg:Viber rdf:type owl:NamedIndividual ,
                  pg:CommunicationChannel ;
         rdfs:label "Viber" .


###  http://example.org/phishguard#WebForm
pg:WebForm rdf:type owl:NamedIndividual ,
                    pg:CommunicationChannel ;
           rdfs:label "Web form" .


###  http://example.org/phishguard#WhatsApp
pg:WhatsApp rdf:type owl:NamedIndividual ,
                     pg:CommunicationChannel ;
            rdfs:label "WhatsApp" .


