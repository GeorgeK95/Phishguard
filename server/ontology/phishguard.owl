@prefix pg: <http://example.org/phishguard#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

pg:PhishGuardOntology a owl:Ontology ;
  rdfs:label "PhishGuard OWL Ontology" ;
  rdfs:comment "Expanded ontology for phishing message analysis, online scams, indicators, channels, attack goals, organizations, risk levels and recommendations." .

pg:DomainConcept a owl:Class ;
  rdfs:label "Domain concept" .

pg:CyberSecurityConcept a owl:Class ;
  rdfs:label "Cybersecurity concept" .

pg:CyberSecurityConcept rdfs:subClassOf pg:DomainConcept .

pg:PhishingMessage a owl:Class ;
  rdfs:label "Phishing message" .

pg:PhishingMessage rdfs:subClassOf pg:CyberSecurityConcept .

pg:AnalysisResult a owl:Class ;
