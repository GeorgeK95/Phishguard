@prefix pg: <http://example.org/phishguard#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

pg:PhishGuardOntology a owl:Ontology ;
  rdfs:label "PhishGuard OWL Ontology" ;
  rdfs:comment "Ontology for phishing message analysis, threat types, message features, risk levels and recommendations." .

pg:ThreatType a owl:Class ;
  rdfs:label "Threat type" .

pg:MessageFeature a owl:Class ;
  rdfs:label "Message feature" .

pg:CommunicationChannel a owl:Class ;
  rdfs:label "Communication channel" .

pg:RiskLevel a owl:Class ;
  rdfs:label "Risk level" .

pg:Recommendation a owl:Class ;
  rdfs:label "Recommendation" .

pg:hasFeature a owl:ObjectProperty ;
  rdfs:label "Threat type has related message feature" .

pg:hasRiskLevel a owl:ObjectProperty ;
  rdfs:label "Analysis or feature has risk level" .

pg:hasRecommendation a owl:ObjectProperty ;
  rdfs:label "Risk level has recommendation" .

pg:usesChannel a owl:ObjectProperty ;
  rdfs:label "Message uses communication channel" .

pg:keyword a owl:DatatypeProperty ;
  rdfs:label "Keyword used for feature detection" .

pg:riskScore a owl:DatatypeProperty ;
  rdfs:label "Risk score contribution" .

pg:description a owl:DatatypeProperty ;
  rdfs:label "Human-readable description" .

pg:minScore a owl:DatatypeProperty ;
  rdfs:label "Minimum score" .

pg:maxScore a owl:DatatypeProperty ;
  rdfs:label "Maximum score" .

pg:LowRisk a pg:RiskLevel ;
  rdfs:label "Low risk" ;
  pg:minScore "0"^^xsd:integer ;
  pg:maxScore "30"^^xsd:integer .

pg:MediumRisk a pg:RiskLevel ;
  rdfs:label "Medium risk" ;
  pg:minScore "31"^^xsd:integer ;
  pg:maxScore "60"^^xsd:integer .

pg:HighRisk a pg:RiskLevel ;
  rdfs:label "High risk" ;
  pg:minScore "61"^^xsd:integer ;
  pg:maxScore "100"^^xsd:integer .

pg:SMS a pg:CommunicationChannel ;
  rdfs:label "SMS" .

pg:Email a pg:CommunicationChannel ;
  rdfs:label "Email" .

pg:ChatMessage a pg:CommunicationChannel ;
  rdfs:label "Chat message" .

pg:SocialMedia a pg:CommunicationChannel ;
  rdfs:label "Social media message" .

pg:Urgency a pg:MessageFeature ;
  rdfs:label "Urgency" ;
  pg:description "The message uses urgency to push the user into a fast reaction." ;
  pg:riskScore "15"^^xsd:integer ;
  pg:keyword "urgent" ;
  pg:keyword "immediately" ;
  pg:keyword "limited time" ;
  pg:keyword "within 24 hours" ;
  pg:keyword "act now" ;
  pg:keyword "right away".

pg:AccountThreat a pg:MessageFeature ;
  rdfs:label "Account threat" ;
  pg:description "The message threatens account blocking, suspension or restriction." ;
  pg:riskScore "20"^^xsd:integer ;
  pg:keyword "suspended" ;
  pg:keyword "blocked" ;
  pg:keyword "restricted" ;
  pg:keyword "account closure" ;
  pg:keyword "deactivated" ;
  pg:keyword "will be blocked".

pg:CredentialRequest a pg:MessageFeature ;
  rdfs:label "Credential request" ;
  pg:description "The message asks for a password, login action or account verification." ;
  pg:riskScore "30"^^xsd:integer ;
  pg:keyword "password" ;
  pg:keyword "login" ;
  pg:keyword "verify your account" ;
  pg:keyword "confirm your account" ;
  pg:keyword "security code" ;
  pg:keyword "2fa code".

pg:PaymentRequest a pg:MessageFeature ;
  rdfs:label "Payment request" ;
  pg:description "The message requests a payment, fee, card details or bank information." ;
  pg:riskScore "25"^^xsd:integer ;
  pg:keyword "pay" ;
  pg:keyword "payment" ;
  pg:keyword "fee" ;
  pg:keyword "card" ;
  pg:keyword "iban" ;
  pg:keyword "bank details" ;
  pg:keyword "billing" ;
  pg:keyword "invoice".

pg:SuspiciousLink a pg:MessageFeature ;
  rdfs:label "Suspicious link" ;
  pg:description "The message contains a link that may lead to a fake or unsafe website." ;
  pg:riskScore "30"^^xsd:integer ;
  pg:keyword "http://" ;
  pg:keyword "bit.ly" ;
  pg:keyword "tinyurl" ;
  pg:keyword "login-" ;
  pg:keyword "secure-" ;
  pg:keyword "verify-" ;
  pg:keyword ".top" ;
  pg:keyword ".xyz".

pg:PrizeBait a pg:MessageFeature ;
  rdfs:label "Prize bait" ;
  pg:description "The message promises a prize, reward or bonus to manipulate the user." ;
  pg:riskScore "20"^^xsd:integer ;
  pg:keyword "prize" ;
  pg:keyword "winner" ;
  pg:keyword "bonus" ;
  pg:keyword "free gift" ;
  pg:keyword "reward" ;
  pg:keyword "congratulations".

pg:UnknownSender a pg:MessageFeature ;
  rdfs:label "Unknown or unclear sender" ;
  pg:description "The message does not clearly identify an official sender or institution." ;
  pg:riskScore "10"^^xsd:integer ;
  pg:keyword "unknown" ;
  pg:keyword "no-reply" ;
  pg:keyword "support-center" ;
  pg:keyword "customer-support" ;
  pg:keyword "service-team".

pg:DeliveryFeeBait a pg:MessageFeature ;
  rdfs:label "Fake delivery fee" ;
  pg:description "The message imitates a delivery provider and asks for a small parcel or shipping fee." ;
  pg:riskScore "25"^^xsd:integer ;
  pg:keyword "delivery" ;
  pg:keyword "parcel" ;
  pg:keyword "shipping fee" ;
  pg:keyword "package" ;
  pg:keyword "customs fee" ;
  pg:keyword "tracking".

pg:FakeBankMessage a pg:ThreatType ;
  rdfs:label "Fake bank message" ;
  pg:description "A scam that imitates a bank in order to steal credentials, personal data or money.";
  pg:hasFeature pg:AccountThreat ;
  pg:hasFeature pg:CredentialRequest ;
  pg:hasFeature pg:PaymentRequest ;
  pg:hasFeature pg:SuspiciousLink.

pg:FakeDeliveryMessage a pg:ThreatType ;
  rdfs:label "Fake delivery message" ;
  pg:description "A scam that imitates a courier or delivery service and asks for a fee or personal data.";
  pg:hasFeature pg:DeliveryFeeBait ;
  pg:hasFeature pg:PaymentRequest ;
  pg:hasFeature pg:SuspiciousLink ;
  pg:hasFeature pg:Urgency.

pg:FakePrizeScam a pg:ThreatType ;
  rdfs:label "Fake prize scam" ;
  pg:description "A scam that promises a prize and leads the user to a link, payment or data request.";
  pg:hasFeature pg:PrizeBait ;
  pg:hasFeature pg:SuspiciousLink ;
  pg:hasFeature pg:PaymentRequest.

pg:CredentialPhishing a pg:ThreatType ;
  rdfs:label "Credential phishing" ;
  pg:description "A phishing attack focused on stealing passwords, security codes or login credentials.";
  pg:hasFeature pg:CredentialRequest ;
  pg:hasFeature pg:SuspiciousLink ;
  pg:hasFeature pg:Urgency.

pg:DoNotOpenLink a pg:Recommendation ;
  rdfs:label "Do not open the link" ;
  pg:description "Do not open any links from this message before verifying the sender through an official source." .

pg:DoNotEnterData a pg:Recommendation ;
  rdfs:label "Do not enter personal data" ;
  pg:description "Do not enter passwords, card details, banking data or personal information through the provided link." .

pg:VerifyOfficialWebsite a pg:Recommendation ;
  rdfs:label "Verify the official website" ;
  pg:description "Open the official website manually in the browser instead of using the link from the message." .

pg:ReportMessage a pg:Recommendation ;
  rdfs:label "Report the message" ;
  pg:description "Report the message as spam or phishing and block the sender if possible." .

