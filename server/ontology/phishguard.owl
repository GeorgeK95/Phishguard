                     rdfs:subClassOf pg:AttackGoal .


###  http://example.org/phishguard#SuspiciousUrl
pg:SuspiciousUrl rdf:type owl:Class ;
                 rdfs:subClassOf pg:LinkFeature ;
                 rdfs:label "Suspicious URL" .


###  http://example.org/phishguard#TakeOverAccount
pg:TakeOverAccount rdf:type owl:Class ;
                   rdfs:subClassOf pg:AttackGoal .


###  http://example.org/phishguard#TargetOrganization
pg:TargetOrganization rdf:type owl:Class ;
                      rdfs:subClassOf pg:CyberSecurityConcept ;
                      rdfs:label "Target organization" .


###  http://example.org/phishguard#TechSupportScam
pg:TechSupportScam rdf:type owl:Class ;
                   rdfs:subClassOf pg:SocialEngineeringThreat .


###  http://example.org/phishguard#TelecomProvider
pg:TelecomProvider rdf:type owl:Class ;
                   rdfs:subClassOf pg:TargetOrganization .


###  http://example.org/phishguard#TelegramChannel
pg:TelegramChannel rdf:type owl:Class ;
                   rdfs:subClassOf pg:CommunicationChannel ;
                   rdfs:label "Telegram channel" .


###  http://example.org/phishguard#ThreatType
pg:ThreatType rdf:type owl:Class ;
              rdfs:subClassOf pg:CyberThreat ;
              rdfs:label "Threat type" .


###  http://example.org/phishguard#ThreateningLanguage
pg:ThreateningLanguage rdf:type owl:Class ;
                       rdfs:subClassOf pg:LinguisticFeature ;
                       rdfs:label "Threatening language" .


###  http://example.org/phishguard#TooGoodToBeTrueLanguage
pg:TooGoodToBeTrueLanguage rdf:type owl:Class ;
                           rdfs:subClassOf pg:LinguisticFeature ;
                           rdfs:label "Too-good-to-be-true language" .


###  http://example.org/phishguard#TwoFactorCodeRequest
pg:TwoFactorCodeRequest rdf:type owl:Class ;
                        rdfs:subClassOf pg:DataRequestFeature .


###  http://example.org/phishguard#TyposquattedDomain
pg:TyposquattedDomain rdf:type owl:Class ;
                      rdfs:subClassOf pg:LinkFeature ;
                      rdfs:label "Typosquatted domain" .


###  http://example.org/phishguard#UnknownSenderClass
pg:UnknownSenderClass rdf:type owl:Class ;
                      rdfs:subClassOf pg:SenderFeature ;
                      rdfs:label "Unknown sender" .


###  http://example.org/phishguard#UrgencyLanguage
pg:UrgencyLanguage rdf:type owl:Class ;
                   rdfs:subClassOf pg:LinguisticFeature ;
                   rdfs:label "Urgency language" .


###  http://example.org/phishguard#UrgentPaymentRequest
pg:UrgentPaymentRequest rdf:type owl:Class ;
                        rdfs:subClassOf pg:PaymentFeature ;
                        rdfs:label "Urgent payment request" .


###  http://example.org/phishguard#UrlEvidence
pg:UrlEvidence rdf:type owl:Class ;
               rdfs:subClassOf pg:Evidence ;
               rdfs:label "URL evidence" .


###  http://example.org/phishguard#UrlWithIPAddress
pg:UrlWithIPAddress rdf:type owl:Class ;
                    rdfs:subClassOf pg:LinkFeature ;
                    rdfs:label "URL with IP address" .


###  http://example.org/phishguard#VerificationAction
pg:VerificationAction rdf:type owl:Class ;
                      rdfs:subClassOf pg:Recommendation ;
                      rdfs:label "Verification action" .


###  http://example.org/phishguard#VerifyOfficialWebsiteClass
pg:VerifyOfficialWebsiteClass rdf:type owl:Class ;
                              rdfs:subClassOf pg:VerificationAction ;
                              rdfs:label "Verify official website" .


###  http://example.org/phishguard#ViberChannel
pg:ViberChannel rdf:type owl:Class ;
                rdfs:subClassOf pg:CommunicationChannel ;
                rdfs:label "Viber channel" .


###  http://example.org/phishguard#VishingThreat
pg:VishingThreat rdf:type owl:Class ;
                 rdfs:subClassOf pg:ThreatType ;
                 rdfs:label "Vishing threat" .


###  http://example.org/phishguard#WhatsAppChannel
pg:WhatsAppChannel rdf:type owl:Class ;
                   rdfs:subClassOf pg:CommunicationChannel ;
                   rdfs:label "WhatsApp channel" .


#################################################################
#    Individuals
#################################################################

###  http://example.org/phishguard#AccountThreat
pg:AccountThreat rdf:type owl:NamedIndividual ,
                          pg:MessageFeature ;
                 pg:description "The message threatens account blocking, suspension, closure or restriction." ;
                 pg:keyword "account suspension" ,
                            "account will be blocked" ,
                            "blocked" ,
                            "closed" ,
                            "deactivated" ,
                            "restricted" ,
                            "suspended" ;
                 pg:riskScore 20 ;
                 rdfs:label "Account threat" .


###  http://example.org/phishguard#AsdAsd
pg:AsdAsd rdf:type owl:NamedIndividual ,
                   pg:ThreatType ;
          pg:hasFeature pg:CredentialRequest ;
          pg:description "asd asd " ;
          rdfs:label "asd asd " .


###  http://example.org/phishguard#AuthorityPressureFeature
pg:AuthorityPressureFeature rdf:type owl:NamedIndividual ,
                                     pg:MessageFeature ;
                            pg:description "The message pretends to be from an authority, police, tax or government body." ;
                            pg:keyword "court notice" ,
                                       "government notice" ,
                                       "legal action" ,
                                       "official request" ,
                                       "police" ,
                                       "tax authority" ;
                            pg:riskScore 15 ;
                            rdfs:label "Authority pressure" .


###  http://example.org/phishguard#AvoidCryptoTransfer
pg:AvoidCryptoTransfer rdf:type owl:NamedIndividual ,
                                pg:Recommendation ;
                       pg:description "Do not send cryptocurrency or wallet information based on an unsolicited message." ;
                       rdfs:label "Avoid crypto transfer" .


###  http://example.org/phishguard#BankOrganization
pg:BankOrganization rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#BypassTwoFactor
pg:BypassTwoFactor rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#CarFakeOffer
pg:CarFakeOffer rdf:type owl:NamedIndividual ,
                         pg:MessageFeature ;
                pg:description "The message offers a vehicle at a suspiciously low price and pushes the user toward unsafe payment." ;
                pg:keyword "audi" ,
                           "bmw" ,
                           "car" ,
                           "deposit" ,
                           "mercedes" ,
                           "shipping from canada" ,
                           "shipping from usa" ,
                           "vehicle" ;
                pg:riskScore 25 ;
                rdfs:label "Fake vehicle offer" .


###  http://example.org/phishguard#CardDataRequest
pg:CardDataRequest rdf:type owl:NamedIndividual ,
                            pg:MessageFeature ;
                   pg:description "The message asks for card number, CVV, expiration date or billing information." ;
                   pg:keyword "billing address" ,
                              "card number" ,
                              "credit card" ,
                              "cvv" ,
                              "debit card" ,
                              "expiration date" ,
                              "expiry date" ;
                   pg:riskScore 35 ;
                   rdfs:label "Card data request" .


###  http://example.org/phishguard#ChangePassword
pg:ChangePassword rdf:type owl:NamedIndividual ,
                           pg:Recommendation ;
                  pg:description "If you entered credentials, change your password from the official website and enable two-factor authentication." ;
                  rdfs:label "Change password" .


###  http://example.org/phishguard#ChatMessage
pg:ChatMessage rdf:type owl:NamedIndividual ,
                        pg:CommunicationChannel ;
               rdfs:label "Chat message" .


###  http://example.org/phishguard#CheckDeliveryOfficially
pg:CheckDeliveryOfficially rdf:type owl:NamedIndividual ,
                                    pg:Recommendation ;
                           pg:description "For delivery messages, check the tracking number only through the official courier website or app." ;
                           rdfs:label "Check delivery officially" .


###  http://example.org/phishguard#ContactBank
pg:ContactBank rdf:type owl:NamedIndividual ,
                        pg:Recommendation ;
               pg:description "If bank or card data may be involved, contact your bank through the official phone number or app." ;
               rdfs:label "Contact your bank" .


###  http://example.org/phishguard#CourierCompany
pg:CourierCompany rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#CredentialPhishing
pg:CredentialPhishing rdf:type owl:NamedIndividual ,
                               pg:ThreatType ;
                      pg:hasAttackGoal pg:StealCredentials ,
                                       pg:TakeOverAccount ;
                      pg:hasFeature pg:CredentialRequest ,
                                    pg:LookalikeDomainFeature ,
                                    pg:SuspiciousLink ,
                                    pg:TwoFactorCodeRequest ,
                                    pg:Urgency ;
                      pg:targetsOrganization pg:OnlineStore ,
                                             pg:PaymentProvider ,
                                             pg:SocialNetwork ;
                      pg:description "A phishing attack that targets passwords, account access and login tokens." ;
                      rdfs:label "Credential phishing" .


###  http://example.org/phishguard#CredentialRequest
pg:CredentialRequest rdf:type owl:NamedIndividual ,
                              pg:MessageFeature ;
                     pg:description "The message asks for password, login credentials or account verification." ;
                     pg:keyword "authentication" ,
                                "confirm your account" ,
                                "credentials" ,
                                "login" ,
                                "password" ,
                                "sign in" ,
                                "verify your account" ;
                     pg:riskScore 30 ;
                     rdfs:label "Credential request" .


###  http://example.org/phishguard#CryptoExchange
pg:CryptoExchange rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#CryptoPaymentRequest
pg:CryptoPaymentRequest rdf:type owl:NamedIndividual ,
                                 pg:MessageFeature ;
                        pg:description "The message requests cryptocurrency payment or wallet transfer." ;
                        pg:keyword "bitcoin" ,
                                   "blockchain" ,
                                   "crypto" ,
                                   "recovery phrase" ,
                                   "seed phrase" ,
                                   "usdt" ,
                                   "wallet" ;
                        pg:riskScore 25 ;
                        rdfs:label "Crypto payment request" .


###  http://example.org/phishguard#CryptoScam
pg:CryptoScam rdf:type owl:NamedIndividual ,
                       pg:ThreatType ;
              pg:hasAttackGoal pg:ReceiveFraudulentPayment ,
                               pg:StealCryptoAssets ;
              pg:hasFeature pg:CryptoPaymentRequest ,
                            pg:InvestmentReturnBait ,
                            pg:SuspiciousLink ,
                            pg:UnknownSender ,
                            pg:Urgency ;
              pg:targetsOrganization pg:CryptoExchange ;
              pg:description "A scam involving cryptocurrency payment, wallet transfer or recovery phrase theft." ;
              rdfs:label "Crypto scam" .


###  http://example.org/phishguard#DeliveryFeeBait
pg:DeliveryFeeBait rdf:type owl:NamedIndividual ,
                            pg:MessageFeature ;
                   pg:description "The message imitates a delivery company and asks for a small fee or data." ;
                   pg:keyword "customs fee" ,
                              "delivery" ,
                              "delivery failed" ,
                              "package" ,
                              "parcel" ,
                              "reschedule delivery" ,
                              "shipping fee" ;
                   pg:riskScore 25 ;
                   rdfs:label "Delivery fee bait" .


###  http://example.org/phishguard#DoNotDownloadAttachment
pg:DoNotDownloadAttachment rdf:type owl:NamedIndividual ,
                                    pg:Recommendation ;
                           pg:description "Do not download or open attachments from unknown or suspicious senders." ;
                           rdfs:label "Do not download attachments" .


###  http://example.org/phishguard#DoNotEnterData
pg:DoNotEnterData rdf:type owl:NamedIndividual ,
                           pg:Recommendation ;
                  pg:description "Do not enter passwords, card details, two-factor codes or personal information through the provided link." ;
                  rdfs:label "Do not enter personal data" .


###  http://example.org/phishguard#DoNotOpenLink
pg:DoNotOpenLink rdf:type owl:NamedIndividual ,
                          pg:Recommendation ;
                 pg:description "Do not open links from the message until you verify the sender through an official channel." ;
                 rdfs:label "Do not open the link" .


###  http://example.org/phishguard#Email
pg:Email rdf:type owl:NamedIndividual ,
                  pg:CommunicationChannel ;
         rdfs:label "Email" .


###  http://example.org/phishguard#FacebookMessenger
pg:FacebookMessenger rdf:type owl:NamedIndividual ,
                              pg:CommunicationChannel ;
                     rdfs:label "Facebook Messenger" .


###  http://example.org/phishguard#FakeBankMessage
pg:FakeBankMessage rdf:type owl:NamedIndividual ,
                            pg:ThreatType ;
                   pg:hasAttackGoal pg:BypassTwoFactor ,
                                    pg:StealCardData ,
                                    pg:StealCredentials ;
                   pg:hasFeature pg:AccountThreat ,
                                 pg:CardDataRequest ,
                                 pg:CredentialRequest ,
                                 pg:PaymentRequest ,
                                 pg:SuspiciousLink ,
                                 pg:TwoFactorCodeRequest ;
                   pg:targetsOrganization pg:BankOrganization ;
                   pg:description "A scam that imitates a bank and tries to steal money, credentials or card data." ;
                   rdfs:label "Fake bank message" .


###  http://example.org/phishguard#FakeDeliveryMessage
pg:FakeDeliveryMessage rdf:type owl:NamedIndividual ,
                                pg:ThreatType ;
                       pg:hasAttackGoal pg:ReceiveFraudulentPayment ,
                                        pg:StealPersonalData ;
                       pg:hasFeature pg:DeliveryFeeBait ,
                                     pg:PaymentRequest ,
                                     pg:SmallFeeRequest ,
                                     pg:SuspiciousLink ,
                                     pg:Urgency ;
                       pg:targetsOrganization pg:CourierCompany ;
                       pg:description "A scam that imitates a courier or delivery service and requests a fee or personal data." ;
                       rdfs:label "Fake delivery message" .


###  http://example.org/phishguard#FakeGuru
pg:FakeGuru rdf:type owl:NamedIndividual ,
                     pg:MessageFeature ;
            pg:description "Wanna get rick quick ? Pay for this course." ;
            pg:keyword "money" ,
                       "quick" ,
                       "rich" ;
            pg:riskScore 25 ;
            rdfs:label "Fake Guru" .


###  http://example.org/phishguard#FakeGuruTrheadType
pg:FakeGuruTrheadType rdf:type owl:NamedIndividual ,
                               pg:ThreatType ;
                      pg:hasFeature pg:FakeGuru ;
                      pg:description "Fake course; scammer." ;
                      rdfs:label "FakeGuruTrheadType" .


###  http://example.org/phishguard#FakePrizeScam
pg:FakePrizeScam rdf:type owl:NamedIndividual ,
                          pg:ThreatType ;
                 pg:hasAttackGoal pg:ReceiveFraudulentPayment ,
                                  pg:StealPersonalData ;
                 pg:hasFeature pg:PaymentRequest ,
                               pg:PersonalDataRequest ,
                               pg:PrizeBait ,
                               pg:SuspiciousLink ;
                 pg:targetsOrganization pg:OnlineStore ,
                                        pg:SocialNetwork ;
                 pg:description "A scam that promises a prize and leads the user to a link, payment or data request." ;
                 rdfs:label "Fake prize scam" .


###  http://example.org/phishguard#FakeVehicleOffer
pg:FakeVehicleOffer rdf:type owl:NamedIndividual ,
                             pg:ThreatType ;
                    pg:hasAttackGoal pg:ReceiveFraudulentPayment ;
                    pg:hasFeature pg:CarFakeOffer ,
                                  pg:PaymentRequest ,
                                  pg:SuspiciousLink ,
                                  pg:UnknownSender ;
                    pg:targetsOrganization pg:OnlineStore ;
                    pg:description "A scam involving a low-price vehicle offer and unsafe deposit/payment request." ;
                    rdfs:label "Fake vehicle offer" .


###  http://example.org/phishguard#GenericGreetingFeature
pg:GenericGreetingFeature rdf:type owl:NamedIndividual ,
                                   pg:MessageFeature ;
                          pg:description "The message uses a generic greeting instead of a specific recipient." ;
                          pg:keyword "dear customer" ,
                                     "dear user" ,
                                     "hello client" ,
                                     "valued customer" ;
                          pg:riskScore 8 ;
                          rdfs:label "Generic greeting" .


###  http://example.org/phishguard#GiftCardPaymentRequest
pg:GiftCardPaymentRequest rdf:type owl:NamedIndividual ,
                                   pg:MessageFeature ;
                          pg:description "The message requests payment through gift cards or voucher codes." ;
                          pg:keyword "gift card" ,
                                     "google play card" ,
                                     "itunes card" ,
                                     "steam card" ,
                                     "voucher code" ;
                          pg:riskScore 30 .


###  http://example.org/phishguard#GovernmentImpersonation
pg:GovernmentImpersonation rdf:type owl:NamedIndividual ,
                                    pg:ThreatType ;
                           pg:hasAttackGoal pg:ReceiveFraudulentPayment ,
                                            pg:StealPersonalData ;
                           pg:hasFeature pg:AuthorityPressureFeature ,
                                         pg:PaymentRequest ,
                                         pg:PersonalDataRequest ,
                                         pg:SuspiciousLink ;
                           pg:targetsOrganization pg:GovernmentInstitution ;
                           pg:description "A scam that pretends to be from a tax, legal or government institution." ;
                           rdfs:label "Government impersonation" .


###  http://example.org/phishguard#GovernmentInstitution
pg:GovernmentInstitution rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#GrammarMistakeFeature
pg:GrammarMistakeFeature rdf:type owl:NamedIndividual ,
                                  pg:MessageFeature ;
                         pg:description "The message contains grammar or spelling patterns often seen in mass phishing." ;
                         pg:keyword "account informations" ,
                                    "dear costumer" ,
                                    "kindly verify" ,
                                    "your informations" ;
                         pg:riskScore 8 ;
                         rdfs:label "Grammar or spelling mistakes" .


###  http://example.org/phishguard#HighRisk
pg:HighRisk rdf:type owl:NamedIndividual ,
                     pg:RiskLevel ;
            pg:riskScore "61-100" ;
            rdfs:label "High risk" .


###  http://example.org/phishguard#HttpWithoutHttpsFeature
pg:HttpWithoutHttpsFeature rdf:type owl:NamedIndividual ,
                                    pg:MessageFeature ;
                           pg:description "The URL uses plain HTTP or another weak trust signal." ;
                           pg:keyword "http://" ;
                           pg:riskScore 15 ;
                           rdfs:label "HTTP without HTTPS" .


###  http://example.org/phishguard#InstagramDM
pg:InstagramDM rdf:type owl:NamedIndividual ,
                        pg:CommunicationChannel ;
               rdfs:label "Instagram DM" .


###  http://example.org/phishguard#InstallMalware
pg:InstallMalware rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#InvestmentReturnBait
pg:InvestmentReturnBait rdf:type owl:NamedIndividual ,
                                 pg:MessageFeature ;
                        pg:description "The message promises unrealistic investment returns." ;
                        pg:keyword "daily profit" ,
                                   "double your money" ,
                                   "guaranteed return" ,
                                   "investment opportunity" ,
                                   "risk-free profit" ;
                        pg:riskScore 25 ;
                        rdfs:label "Investment return bait" .


###  http://example.org/phishguard#InvestmentScam
pg:InvestmentScam rdf:type owl:NamedIndividual ,
                           pg:ThreatType ;
                  pg:hasAttackGoal pg:ReceiveFraudulentPayment ,
                                   pg:StealCryptoAssets ;
                  pg:hasFeature pg:CryptoPaymentRequest ,
                                pg:InvestmentReturnBait ,
                                pg:PaymentRequest ,
                                pg:UnknownSender ;
                  pg:targetsOrganization pg:CryptoExchange ;
                  pg:description "A scam that promises unrealistic investment profits and asks for money or account details." .


###  http://example.org/phishguard#LookalikeDomainFeature
pg:LookalikeDomainFeature rdf:type owl:NamedIndividual ,
                                   pg:MessageFeature ;
                          pg:description "The URL imitates a trusted brand using misleading domain structure." ;
                          pg:keyword "apple-support" ,
                                     "g00gle" ,
                                     "login-bank" ,
                                     "micros0ft" ,
                                     "paypaI" ,
                                     "secure-bank" ;
                          pg:riskScore 30 ;
                          rdfs:label "Lookalike domain" .


###  http://example.org/phishguard#LowRisk
pg:LowRisk rdf:type owl:NamedIndividual ,
                    pg:RiskLevel ;
           pg:riskScore "0-30" ;
           rdfs:label "Low risk" .


###  http://example.org/phishguard#MaliciousAttachmentFeature
pg:MaliciousAttachmentFeature rdf:type owl:NamedIndividual ,
                                       pg:MessageFeature ;
                              pg:description "The message tries to make the user open an attachment or document." ;
                              pg:keyword ".exe" ,
                                         ".scr" ,
                                         ".zip" ,
                                         "attached invoice" ,
                                         "download document" ,
                                         "enable macros" ,
                                         "open the attachment" ;
                              pg:riskScore 30 ;
                              rdfs:label "Malicious attachment signal" .


###  http://example.org/phishguard#MalwareAttachmentScam
pg:MalwareAttachmentScam rdf:type owl:NamedIndividual ,
                                  pg:ThreatType ;
                         pg:hasAttackGoal pg:InstallMalware ;
                         pg:hasFeature pg:MaliciousAttachmentFeature ,
                                       pg:UnknownSender ,
                                       pg:Urgency ;
                         pg:targetsOrganization pg:OnlineStore ;
                         pg:description "A scam that attempts to make the user open a malicious file or macro-enabled document." ;
                         rdfs:label "Malware attachment scam" .


###  http://example.org/phishguard#MediumRisk
pg:MediumRisk rdf:type owl:NamedIndividual ,
                       pg:RiskLevel ;
              pg:riskScore "31-60" ;
              rdfs:label "Medium risk" .


###  http://example.org/phishguard#OnlineStore
pg:OnlineStore rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#PaymentProvider
pg:PaymentProvider rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#PaymentRequest
pg:PaymentRequest rdf:type owl:NamedIndividual ,
                           pg:MessageFeature ;
                  pg:description "The message requests a payment, fee, card details, bank transfer or billing update." ;
                  pg:keyword "bank details" ,
                             "billing" ,
                             "card" ,
                             "fee" ,
                             "iban" ,
                             "invoice" ,
                             "pay now" ,
                             "payment" ,
                             "transfer" ;
                  pg:riskScore 25 ;
                  rdfs:label "Payment request" .


###  http://example.org/phishguard#PersonalDataRequest
pg:PersonalDataRequest rdf:type owl:NamedIndividual ,
                                pg:MessageFeature ;
                       pg:description "The message asks for personal information such as ID number, address or document photo." ;
                       pg:keyword "address" ,
                                  "date of birth" ,
                                  "document photo" ,
                                  "id card" ,
                                  "identity verification" ,
                                  "passport" ,
                                  "personal data" ;
                       pg:riskScore 25 ;
                       rdfs:label "Personal data request" .


###  http://example.org/phishguard#PhoneCall
pg:PhoneCall rdf:type owl:NamedIndividual ,
                      pg:CommunicationChannel ;
             rdfs:label "Phone call" .


###  http://example.org/phishguard#PreserveEvidence
pg:PreserveEvidence rdf:type owl:NamedIndividual ,
                             pg:Recommendation ;
                    pg:description "Keep a screenshot or copy of the message if you need to report the scam." ;
                    rdfs:label "Preserve evidence" .


###  http://example.org/phishguard#PrizeBait
pg:PrizeBait rdf:type owl:NamedIndividual ,
                      pg:MessageFeature ;
             pg:description "The message promises a prize, bonus, giveaway or reward to manipulate the user." ;
             pg:keyword "bonus" ,
                        "free gift" ,
                        "giveaway" ,
                        "prize" ,
                        "reward" ,
                        "winner" ,
                        "you have won" ;
             pg:riskScore 20 ;
             rdfs:label "Prize bait" .


###  http://example.org/phishguard#QRCode
pg:QRCode rdf:type owl:NamedIndividual ,
                   pg:CommunicationChannel ;
          rdfs:label "QR code" .


###  http://example.org/phishguard#QRCodePrompt
pg:QRCodePrompt rdf:type owl:NamedIndividual ,
                         pg:MessageFeature ;
                pg:description "The message asks the user to scan a QR code for login, payment or verification." ;
                pg:keyword "qr code" ,
                           "qr payment" ,
                           "scan qr" ,
                           "scan the code" ;
                pg:riskScore 20 ;
                rdfs:label "QR code prompt" .


###  http://example.org/phishguard#QRPhishing
pg:QRPhishing rdf:type owl:NamedIndividual ,
                       pg:ThreatType ;
              pg:hasAttackGoal pg:StealCardData ,
                               pg:StealCredentials ;
              pg:hasFeature pg:CredentialRequest ,
                            pg:QRCodePrompt ,
                            pg:SuspiciousLink ;
              pg:targetsOrganization pg:BankOrganization ,
                                     pg:PaymentProvider ;
              pg:description "A phishing attempt that uses a QR code to redirect the user to a malicious page." ;
              rdfs:label "QR phishing" .


###  http://example.org/phishguard#ReceiveFraudulentPayment
pg:ReceiveFraudulentPayment rdf:type owl:NamedIndividual .


###  http://example.org/phishguard#RefundBait
pg:RefundBait rdf:type owl:NamedIndividual ,
                       pg:MessageFeature ;
              pg:description "The message promises a refund in exchange for login, card or personal details." ;
              pg:keyword "claim refund" ,
                         "money back" ,
                         "refund" ,
                         "reimbursement" ,
                         "tax refund" ;
              pg:riskScore 20 ;
              rdfs:label "Refund bait" .


###  http://example.org/phishguard#RefundScam
pg:RefundScam rdf:type owl:NamedIndividual ,
                       pg:ThreatType ;
              pg:hasAttackGoal pg:StealCardData ,
                               pg:StealPersonalData ;
              pg:hasFeature pg:CardDataRequest ,
                            pg:PersonalDataRequest ,
                            pg:RefundBait ,
                            pg:SuspiciousLink ;
              pg:targetsOrganization pg:GovernmentInstitution ,
                                     pg:OnlineStore ,
                                     pg:PaymentProvider ;
              pg:description "A scam that uses a fake refund to collect card or personal details." .


###  http://example.org/phishguard#ReportMessage
pg:ReportMessage rdf:type owl:NamedIndividual ,
                          pg:Recommendation ;
                 pg:description "Report the message as spam or phishing and block the sender if possible." ;
                 rdfs:label "Report the message" .


###  http://example.org/phishguard#SMS
pg:SMS rdf:type owl:NamedIndividual ,
                pg:CommunicationChannel ;
       rdfs:label "SMS" .


###  http://example.org/phishguard#ShortenedUrlFeature
pg:ShortenedUrlFeature rdf:type owl:NamedIndividual ,
                                pg:MessageFeature ;
                       pg:description "The message uses a shortened URL that hides the final destination." ;
                       pg:keyword "bit.ly" ,
                                  "goo.gl" ,
                                  "ow.ly" ,
                                  "rebrand.ly" ,
                                  "t.co" ,
                                  "tinyurl" ;
                       pg:riskScore 20 ;
                       rdfs:label "Shortened URL" .


###  http://example.org/phishguard#SmallFeeRequest
pg:SmallFeeRequest rdf:type owl:NamedIndividual .


