pg:DoNotOpenLink a pg:Recommendation ;
  rdfs:label "Do not open the link" ;
  pg:description "Do not open links from the message until you verify the sender through an official channel." .

pg:DoNotEnterData a pg:Recommendation ;
  rdfs:label "Do not enter personal data" ;
  pg:description "Do not enter passwords, card details, two-factor codes or personal information through the provided link." .

pg:VerifyOfficialWebsite a pg:Recommendation ;
  rdfs:label "Verify through the official website" ;
  pg:description "Open the official website manually in your browser instead of using the received link." .

pg:ReportMessage a pg:Recommendation ;
  rdfs:label "Report the message" ;
  pg:description "Report the message as spam or phishing and block the sender if possible." .

pg:ContactBank a pg:Recommendation ;
  rdfs:label "Contact your bank" ;
  pg:description "If bank or card data may be involved, contact your bank through the official phone number or app." .

pg:ChangePassword a pg:Recommendation ;
  rdfs:label "Change password" ;
  pg:description "If you entered credentials, change your password from the official website and enable two-factor authentication." .

pg:DoNotDownloadAttachment a pg:Recommendation ;
  rdfs:label "Do not download attachments" ;
  pg:description "Do not download or open attachments from unknown or suspicious senders." .

pg:CheckDeliveryOfficially a pg:Recommendation ;
  rdfs:label "Check delivery officially" ;
  pg:description "For delivery messages, check the tracking number only through the official courier website or app." .

pg:AvoidCryptoTransfer a pg:Recommendation ;
  rdfs:label "Avoid crypto transfer" ;
  pg:description "Do not send cryptocurrency or wallet information based on an unsolicited message." .

pg:PreserveEvidence a pg:Recommendation ;
  rdfs:label "Preserve evidence" ;
  pg:description "Keep a screenshot or copy of the message if you need to report the scam." .

