@prefix pg: <http://example.org/phishguard#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

pg:PhishGuardOntology a owl:Ontology ;
  rdfs:label "PhishGuard OWL Ontology" ;
  rdfs:comment "Minimal ontology schema for phishing message analysis. This experimental branch starts without predefined individuals." .

pg:ThreatType a owl:Class ;
  rdfs:label "Threat type" .

pg:MessageFeature a owl:Class ;
  rdfs:label "Message feature" .

pg:CommunicationChannel a owl:Class ;
  rdfs:label "Communication channel" .

pg:RiskLevel a owl:Class ;
  rdfs:label "Risk level" .

pg:Recommendation a owl:Class ;
  rdfs:label "Recommendation" .

pg:hasFeature a owl:ObjectProperty ;
  rdfs:label "Threat type has related message feature" .

pg:hasRiskLevel a owl:ObjectProperty ;
  rdfs:label "Analysis or feature has risk level" .

pg:hasRecommendation a owl:ObjectProperty ;
  rdfs:label "Risk level has recommendation" .

pg:usesChannel a owl:ObjectProperty ;
  rdfs:label "Message uses communication channel" .

pg:keyword a owl:DatatypeProperty ;
  rdfs:label "Keyword used for feature detection" .

pg:riskScore a owl:DatatypeProperty ;
  rdfs:label "Risk score contribution" .

pg:description a owl:DatatypeProperty ;
  rdfs:label "Entity description" .
