pg:hasFeature a owl:ObjectProperty ;
  rdfs:label "Threat type has related message feature" .
pg:hasFeature rdfs:domain pg:ThreatType .
pg:hasFeature rdfs:range pg:MessageFeature .

pg:indicatesThreat a owl:ObjectProperty ;
  rdfs:label "Feature indicates threat" .
pg:indicatesThreat rdfs:domain pg:MessageFeature .
pg:indicatesThreat rdfs:range pg:ThreatType .

pg:hasRiskLevel a owl:ObjectProperty ;
  rdfs:label "Analysis has risk level" .
pg:hasRiskLevel rdfs:domain pg:AnalysisResult .
pg:hasRiskLevel rdfs:range pg:RiskLevel .

pg:hasRecommendation a owl:ObjectProperty ;
  rdfs:label "Risk level has recommendation" .
pg:hasRecommendation rdfs:domain pg:RiskLevel .
pg:hasRecommendation rdfs:range pg:Recommendation .

pg:usesChannel a owl:ObjectProperty ;
  rdfs:label "Message uses communication channel" .
pg:usesChannel rdfs:domain pg:PhishingMessage .
pg:usesChannel rdfs:range pg:CommunicationChannel .

pg:targetsOrganization a owl:ObjectProperty ;
  rdfs:label "Threat targets organization type" .
pg:targetsOrganization rdfs:domain pg:ThreatType .
pg:targetsOrganization rdfs:range pg:TargetOrganization .

pg:hasAttackGoal a owl:ObjectProperty ;
  rdfs:label "Threat has attack goal" .
pg:hasAttackGoal rdfs:domain pg:ThreatType .
pg:hasAttackGoal rdfs:range pg:AttackGoal .

pg:requiresAction a owl:ObjectProperty ;
  rdfs:label "Threat requires protective action" .
pg:requiresAction rdfs:domain pg:ThreatType .
pg:requiresAction rdfs:range pg:Recommendation .

pg:detectedInMessage a owl:ObjectProperty ;
  rdfs:label "Feature detected in message" .
pg:detectedInMessage rdfs:domain pg:MessageFeature .
pg:detectedInMessage rdfs:range pg:PhishingMessage .

pg:hasEvidence a owl:ObjectProperty ;
  rdfs:label "Analysis has evidence" .
pg:hasEvidence rdfs:domain pg:AnalysisResult .
pg:hasEvidence rdfs:range pg:Evidence .

pg:containsUrlFeature a owl:ObjectProperty ;
  rdfs:label "Message contains URL feature" .
pg:containsUrlFeature rdfs:domain pg:PhishingMessage .
pg:containsUrlFeature rdfs:range pg:LinkFeature .

pg:hasSenderFeature a owl:ObjectProperty ;
  rdfs:label "Message has sender feature" .
pg:hasSenderFeature rdfs:domain pg:PhishingMessage .
pg:hasSenderFeature rdfs:range pg:SenderFeature .

pg:isFeatureOf a owl:ObjectProperty ;
  rdfs:label "Feature is feature of threat" .
pg:isFeatureOf rdfs:domain pg:MessageFeature .
pg:isFeatureOf rdfs:range pg:ThreatType .
pg:isFeatureOf owl:inverseOf pg:hasFeature .

pg:mitigatesThreat a owl:ObjectProperty ;
  rdfs:label "Recommendation mitigates threat" .
pg:mitigatesThreat rdfs:domain pg:Recommendation .
pg:mitigatesThreat rdfs:range pg:ThreatType .

pg:isEvidenceFor a owl:ObjectProperty ;
  rdfs:label "Evidence supports analysis" .
pg:isEvidenceFor rdfs:domain pg:Evidence .
pg:isEvidenceFor rdfs:range pg:AnalysisResult .

pg:keyword a owl:DatatypeProperty ;
  rdfs:label "Keyword used for feature detection" .
pg:keyword rdfs:domain pg:MessageFeature .
pg:keyword rdfs:range xsd:string .

pg:riskScore a owl:DatatypeProperty ;
  rdfs:label "Risk score contribution" .
pg:riskScore rdfs:domain pg:MessageFeature .
pg:riskScore rdfs:range xsd:integer .

pg:description a owl:DatatypeProperty ;
  rdfs:label "Entity description" .
pg:description rdfs:domain pg:CyberSecurityConcept .
pg:description rdfs:range xsd:string .

pg:hasSeverityWeight a owl:DatatypeProperty ;
  rdfs:label "Severity weight" .
pg:hasSeverityWeight rdfs:domain pg:MessageFeature .
pg:hasSeverityWeight rdfs:range xsd:integer .

pg:hasConfidenceScore a owl:DatatypeProperty ;
  rdfs:label "Confidence score" .
pg:hasConfidenceScore rdfs:domain pg:AnalysisResult .
pg:hasConfidenceScore rdfs:range xsd:decimal .

pg:hasMessageText a owl:DatatypeProperty ;
  rdfs:label "Message text" .
pg:hasMessageText rdfs:domain pg:PhishingMessage .
pg:hasMessageText rdfs:range xsd:string .

pg:hasDetectedAt a owl:DatatypeProperty ;
  rdfs:label "Detected timestamp" .
pg:hasDetectedAt rdfs:domain pg:AnalysisResult .
pg:hasDetectedAt rdfs:range xsd:dateTime .

pg:hasDomainName a owl:DatatypeProperty ;
  rdfs:label "Domain name" .
pg:hasDomainName rdfs:domain pg:UrlEvidence .
pg:hasDomainName rdfs:range xsd:string .

pg:hasSenderValue a owl:DatatypeProperty ;
  rdfs:label "Sender value" .
pg:hasSenderValue rdfs:domain pg:SenderEvidence .
pg:hasSenderValue rdfs:range xsd:string .

pg:hasRiskExplanation a owl:DatatypeProperty ;
  rdfs:label "Risk explanation" .
pg:hasRiskExplanation rdfs:domain pg:AnalysisResult .
pg:hasRiskExplanation rdfs:range xsd:string .

pg:LowRisk a pg:RiskLevel ;
  rdfs:label "Low risk" ;
  pg:riskScore "0-30" .

pg:MediumRisk a pg:RiskLevel ;
  rdfs:label "Medium risk" ;
  pg:riskScore "31-60" .

pg:HighRisk a pg:RiskLevel ;
  rdfs:label "High risk" ;
  pg:riskScore "61-100" .

pg:SMS a pg:CommunicationChannel ;
  rdfs:label "SMS" .

pg:Email a pg:CommunicationChannel ;
  rdfs:label "Email" .

pg:ChatMessage a pg:CommunicationChannel ;
  rdfs:label "Chat message" .

pg:SocialMedia a pg:CommunicationChannel ;
  rdfs:label "Social media" .

pg:WhatsApp a pg:CommunicationChannel ;
  rdfs:label "WhatsApp" .

pg:Viber a pg:CommunicationChannel ;
  rdfs:label "Viber" .

pg:Telegram a pg:CommunicationChannel ;
  rdfs:label "Telegram" .

pg:InstagramDM a pg:CommunicationChannel ;
  rdfs:label "Instagram DM" .

pg:FacebookMessenger a pg:CommunicationChannel ;
  rdfs:label "Facebook Messenger" .

pg:PhoneCall a pg:CommunicationChannel ;
  rdfs:label "Phone call" .

pg:QRCode a pg:CommunicationChannel ;
  rdfs:label "QR code" .

pg:WebForm a pg:CommunicationChannel ;
  rdfs:label "Web form" .

pg:Urgency a pg:MessageFeature ;
  rdfs:label "Urgency language" ;
  pg:description "The message pushes the user to act quickly without proper verification." ;
  pg:riskScore "15"^^xsd:integer ;
  pg:keyword "urgent" ;
  pg:keyword "immediately" ;
  pg:keyword "limited time" ;
  pg:keyword "within 24 hours" ;
  pg:keyword "act now" ;
  pg:keyword "final notice" ;
  pg:keyword "expires today" .

pg:AccountThreat a pg:MessageFeature ;
  rdfs:label "Account threat" ;
  pg:description "The message threatens account blocking, suspension, closure or restriction." ;
  pg:riskScore "20"^^xsd:integer ;
  pg:keyword "blocked" ;
  pg:keyword "suspended" ;
  pg:keyword "restricted" ;
  pg:keyword "closed" ;
  pg:keyword "deactivated" ;
  pg:keyword "account will be blocked" ;
  pg:keyword "account suspension" .

pg:CredentialRequest a pg:MessageFeature ;
  rdfs:label "Credential request" ;
  pg:description "The message asks for password, login credentials or account verification." ;
  pg:riskScore "30"^^xsd:integer ;
  pg:keyword "password" ;
  pg:keyword "login" ;
  pg:keyword "sign in" ;
  pg:keyword "verify your account" ;
  pg:keyword "confirm your account" ;
  pg:keyword "authentication" ;
  pg:keyword "credentials" .

pg:PaymentRequest a pg:MessageFeature ;
  rdfs:label "Payment request" ;
  pg:description "The message requests a payment, fee, card details, bank transfer or billing update." ;
  pg:riskScore "25"^^xsd:integer ;
  pg:keyword "payment" ;
  pg:keyword "pay now" ;
  pg:keyword "fee" ;
  pg:keyword "card" ;
  pg:keyword "iban" ;
  pg:keyword "bank details" ;
  pg:keyword "billing" ;
  pg:keyword "invoice" ;
  pg:keyword "transfer" .

pg:SuspiciousLink a pg:MessageFeature ;
  rdfs:label "Suspicious link" ;
  pg:description "The message contains a URL that may lead to a fake or unsafe website." ;
  pg:riskScore "30"^^xsd:integer ;
  pg:keyword "http://" ;
  pg:keyword "bit.ly" ;
  pg:keyword "tinyurl" ;
  pg:keyword "login-" ;
  pg:keyword "secure-" ;
  pg:keyword "verify-" ;
  pg:keyword ".top" ;
  pg:keyword ".xyz" ;
  pg:keyword ".click" .

pg:PrizeBait a pg:MessageFeature ;
