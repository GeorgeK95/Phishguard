@prefix : <http://example.org/phishguard#PhishGuardOntology> .
@prefix pg: <http://example.org/phishguard#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/phishguard#PhishGuardOntology> .

<http://example.org/phishguard#PhishGuardOntology> rdf:type owl:Ontology ;
                                                    rdfs:comment "Expanded ontology for phishing message analysis, online scams, indicators, channels, attack goals, organizations, risk levels and recommendations." ;
                                                    rdfs:label "PhishGuard OWL Ontology" .

#################################################################
#    Object Properties
#################################################################

###  http://example.org/phishguard#containsUrlFeature
pg:containsUrlFeature rdf:type owl:ObjectProperty ;
                      rdfs:domain pg:PhishingMessage ;
                      rdfs:range pg:LinkFeature ;
                      rdfs:label "Message contains URL feature" .


###  http://example.org/phishguard#detectedInMessage
pg:detectedInMessage rdf:type owl:ObjectProperty ;
                     rdfs:domain pg:MessageFeature ;
                     rdfs:range pg:PhishingMessage ;
                     rdfs:label "Feature detected in message" .


###  http://example.org/phishguard#hasAttackGoal
pg:hasAttackGoal rdf:type owl:ObjectProperty ;
                 rdfs:domain pg:ThreatType ;
                 rdfs:range pg:AttackGoal ;
                 rdfs:label "Threat has attack goal" .


###  http://example.org/phishguard#hasEvidence
pg:hasEvidence rdf:type owl:ObjectProperty ;
               rdfs:domain pg:AnalysisResult ;
               rdfs:range pg:Evidence ;
               rdfs:label "Analysis has evidence" .


###  http://example.org/phishguard#hasFeature
pg:hasFeature rdf:type owl:ObjectProperty ;
              owl:inverseOf pg:isFeatureOf ;
              rdfs:domain pg:ThreatType ;
              rdfs:range pg:MessageFeature ;
              rdfs:label "Threat type has related message feature" .


###  http://example.org/phishguard#hasRecommendation
pg:hasRecommendation rdf:type owl:ObjectProperty ;
                     rdfs:domain pg:RiskLevel ;
                     rdfs:range pg:Recommendation ;
                     rdfs:label "Risk level has recommendation" .


###  http://example.org/phishguard#hasRiskLevel
pg:hasRiskLevel rdf:type owl:ObjectProperty ;
                rdfs:domain pg:AnalysisResult ;
                rdfs:range pg:RiskLevel ;
                rdfs:label "Analysis has risk level" .


###  http://example.org/phishguard#hasSenderFeature
pg:hasSenderFeature rdf:type owl:ObjectProperty ;
                    rdfs:domain pg:PhishingMessage ;
                    rdfs:range pg:SenderFeature ;
                    rdfs:label "Message has sender feature" .


###  http://example.org/phishguard#indicatesThreat
pg:indicatesThreat rdf:type owl:ObjectProperty ;
                   rdfs:domain pg:MessageFeature ;
                   rdfs:range pg:ThreatType ;
                   rdfs:label "Feature indicates threat" .


###  http://example.org/phishguard#isEvidenceFor
pg:isEvidenceFor rdf:type owl:ObjectProperty ;
                 rdfs:domain pg:Evidence ;
                 rdfs:range pg:AnalysisResult ;
                 rdfs:label "Evidence supports analysis" .


###  http://example.org/phishguard#isFeatureOf
pg:isFeatureOf rdf:type owl:ObjectProperty ;
               rdfs:domain pg:MessageFeature ;
               rdfs:range pg:ThreatType ;
               rdfs:label "Feature is feature of threat" .


###  http://example.org/phishguard#mitigatesThreat
pg:mitigatesThreat rdf:type owl:ObjectProperty ;
                   rdfs:domain pg:Recommendation ;
                   rdfs:range pg:ThreatType ;
                   rdfs:label "Recommendation mitigates threat" .


###  http://example.org/phishguard#requiresAction
pg:requiresAction rdf:type owl:ObjectProperty ;
                  rdfs:domain pg:ThreatType ;
                  rdfs:range pg:Recommendation ;
                  rdfs:label "Threat requires protective action" .


###  http://example.org/phishguard#targetsOrganization
pg:targetsOrganization rdf:type owl:ObjectProperty ;
                       rdfs:domain pg:ThreatType ;
                       rdfs:range pg:TargetOrganization ;
                       rdfs:label "Threat targets organization type" .


###  http://example.org/phishguard#usesChannel
pg:usesChannel rdf:type owl:ObjectProperty ;
               rdfs:domain pg:PhishingMessage ;
               rdfs:range pg:CommunicationChannel ;
               rdfs:label "Message uses communication channel" .


#################################################################
#    Data properties
#################################################################

###  http://example.org/phishguard#description
pg:description rdf:type owl:DatatypeProperty ;
               rdfs:domain pg:CyberSecurityConcept ;
               rdfs:range xsd:string ;
               rdfs:label "Entity description" .


###  http://example.org/phishguard#hasConfidenceScore
pg:hasConfidenceScore rdf:type owl:DatatypeProperty ;
                      rdfs:domain pg:AnalysisResult ;
                      rdfs:range xsd:decimal ;
                      rdfs:label "Confidence score" .


###  http://example.org/phishguard#hasDetectedAt
pg:hasDetectedAt rdf:type owl:DatatypeProperty ;
                 rdfs:domain pg:AnalysisResult ;
                 rdfs:range xsd:dateTime ;
                 rdfs:label "Detected timestamp" .


###  http://example.org/phishguard#hasDomainName
pg:hasDomainName rdf:type owl:DatatypeProperty ;
                 rdfs:domain pg:UrlEvidence ;
                 rdfs:range xsd:string ;
                 rdfs:label "Domain name" .


###  http://example.org/phishguard#hasMessageText
pg:hasMessageText rdf:type owl:DatatypeProperty ;
                  rdfs:domain pg:PhishingMessage ;
                  rdfs:range xsd:string ;
                  rdfs:label "Message text" .


###  http://example.org/phishguard#hasRiskExplanation
pg:hasRiskExplanation rdf:type owl:DatatypeProperty ;
                      rdfs:domain pg:AnalysisResult ;
                      rdfs:range xsd:string ;
                      rdfs:label "Risk explanation" .


###  http://example.org/phishguard#hasSenderValue
pg:hasSenderValue rdf:type owl:DatatypeProperty ;
                  rdfs:domain pg:SenderEvidence ;
                  rdfs:range xsd:string ;
                  rdfs:label "Sender value" .


###  http://example.org/phishguard#hasSeverityWeight
pg:hasSeverityWeight rdf:type owl:DatatypeProperty ;
                     rdfs:domain pg:MessageFeature ;
                     rdfs:range xsd:integer ;
                     rdfs:label "Severity weight" .


###  http://example.org/phishguard#keyword
pg:keyword rdf:type owl:DatatypeProperty ;
           rdfs:domain pg:MessageFeature ;
           rdfs:range xsd:string ;
           rdfs:label "Keyword used for feature detection" .


###  http://example.org/phishguard#riskScore
pg:riskScore rdf:type owl:DatatypeProperty ;
             rdfs:domain pg:MessageFeature ;
             rdfs:label "Risk score contribution" .


#################################################################
#    Classes
#################################################################

###  http://example.org/phishguard#AnalysisResult
pg:AnalysisResult rdf:type owl:Class ;
                  rdfs:subClassOf pg:CyberSecurityConcept ;
                  rdfs:label "Analysis result" .


###  http://example.org/phishguard#ArchiveAttachment
pg:ArchiveAttachment rdf:type owl:Class ;
                     rdfs:subClassOf pg:AttachmentFeature ;
                     rdfs:label "Archive attachment" .


###  http://example.org/phishguard#AttachmentFeature
pg:AttachmentFeature rdf:type owl:Class ;
                     rdfs:subClassOf pg:MessageFeature ;
                     rdfs:label "Attachment feature" .


###  http://example.org/phishguard#AttackGoal
pg:AttackGoal rdf:type owl:Class ;
              rdfs:subClassOf pg:CyberSecurityConcept ;
              rdfs:label "Attack goal" .


###  http://example.org/phishguard#AuthorityPressure
pg:AuthorityPressure rdf:type owl:Class ;
                     rdfs:subClassOf pg:LinguisticFeature ;
                     rdfs:label "Authority pressure" .


###  http://example.org/phishguard#BankOrganization
pg:BankOrganization rdf:type owl:Class ;
                    rdfs:subClassOf pg:TargetOrganization .


###  http://example.org/phishguard#BankTransferRequest
pg:BankTransferRequest rdf:type owl:Class ;
